type Configs map[string]*Config

type Config struct {
	URL          string     `mapstructure:"url" json:"url" yaml:"url"`
	TLS          *TLSConfig `mapstructure:"tls" json:"tls" yaml:"tls"`
	Kind         string     `mapstructure:"kind" json:"kind" yaml:"kind"`
	ExchangeName string     `mapstructure:"exchange_name" json:"exchange_name" yaml:"exchange_name"`
	QueueName    string     `mapstructure:"queue_name" json:"queue_name" yaml:"queue_name"`
	RoutingKeys  []string   `mapstructure:"routing_keys" json:"routing_keys" yaml:"routing_keys"`
	ExternalAuth bool
}

type TLSConfig struct {
	PEMFile  string `mapstructure:"pem_file" json:"pem_file" yaml:"pem_file"`
	CertFile string `mapstructure:"cert_file" json:"cert_file" yaml:"cert_file"`
	KeyFile  string `mapstructure:"key_file" json:"key_file" yaml:"key_file"`
}

func NewPublishers(configs Configs) (map[string]stream.Publisher, error) {
	publishers := make(map[string]stream.Publisher)
	for key, config := range configs {
		var publisher stream.Publisher
		var err error
		switch config.Kind {
		case "queue":
			publisher, err = newQueuePublisher(config)
		case "work_queue":
			publisher, err = newWorkQueuePublisher(config)
		case "fanout":
			publisher, err = newFanOutPublisher(config)
		case "direct":
			publisher, err = newDirectPublisher(config)
		case "topic":
			publisher, err = newTopicPublisher(config)
		default:
			return nil, fmt.Errorf("unknown kind: %s", config.Kind)
		}
		if err != nil {
			return nil, err
		}
		publishers[key] = publisher
	}
	return publishers, nil
}

func NewSubscribers(configs Configs) (map[string]stream.Subscriber, error) {
	subscribers := make(map[string]stream.Subscriber)
	for key, config := range configs {
		var subscriber stream.Subscriber
		var err error
		switch config.Kind {
		case "queue":
			subscriber, err = newQueueSubscriber(config)
		case "work_queue":
			subscriber, err = newWorkQueueSubscriber(config)
		case "fanout":
			subscriber, err = newFanOutSubscriber(config)
		case "direct":
			subscriber, err = newDirectSubscriber(config)
		case "topic":
			subscriber, err = newTopicSubscriber(config)
		default:
			return nil, fmt.Errorf("unknown kind: %s", config.Kind)
		}
		if err != nil {
			return nil, err
		}
		subscribers[key] = subscriber
	}
	return subscribers, nil
}

func newQueuePublisher(conf *Config) (stream.Publisher, error) {
	return amqp.NewPublisher(
		conf.QueueName,
		factory(conf, nil),
		amqp.QueueName(func(topic string) string { return topic }),
		amqp.RoutingKeys(func(topic string) []string { return []string{topic} }),
		amqp.QueueOptions(&amqp.QueueOption{
			Durable:    false,
			AutoDelete: false,
			Exclusive:  false,
			NoWait:     false,
			Args:       nil,
		}),
	)
}

