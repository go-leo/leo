func factory(conf *Config, amqp091Conf *amqp091.Config) func(topic string) (*amqp091.Connection, error) {
	return func(topic string) (*amqp091.Connection, error) {
		if len(conf.URL) <= 0 {
			return nil, errors.New("url is nil")
		}
		if amqp091Conf != nil {
			return amqp091.DialConfig(conf.URL, *amqp091Conf)
		}

		if conf.TLS == nil {
			return amqp091.Dial(conf.URL)
		}
		tlsCfg := new(tls.Config)
		tlsCfg.RootCAs = x509.NewCertPool()
		if ca, err := os.ReadFile(conf.TLS.PEMFile); err == nil {
			tlsCfg.RootCAs.AppendCertsFromPEM(ca)
		}
		if cert, err := tls.LoadX509KeyPair(conf.TLS.CertFile, conf.TLS.KeyFile); err == nil {
			tlsCfg.Certificates = append(tlsCfg.Certificates, cert)
		}
		if conf.ExternalAuth {
			return amqp091.DialTLS_ExternalAuth(conf.URL, tlsCfg)
		}
		return amqp091.DialTLS(conf.URL, tlsCfg)
	}
}
