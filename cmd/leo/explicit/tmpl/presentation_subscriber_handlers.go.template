package {{ .Package }}

import (
	"codeup.aliyun.com/qimao/leo/leo/stream"
	"{{ .ModuleName }}/internal/{{ .AppPath }}/application/command"
	"{{ .ModuleName }}/internal/{{ .AppPath }}/application/query"
	"{{ .ModuleName }}/internal/{{ .AppPath }}/presentation/assembler"
)

func NewHandlers(commands *command.Commands, assemblers *assembler.Assemblers, subscribers map[string]stream.Subscriber) []stream.Handler {
	return []stream.Handler{
		New{{ .AppUpperBaseName }}Handler(commands, assemblers, subscribers),
	}
}

func NewPubSubHandlers(queries *query.Queries, assemblers *assembler.Assemblers, subscribers map[string]stream.Subscriber, publishers map[string]stream.Publisher) []stream.PubSubHandler {
	return []stream.PubSubHandler{
		New{{ .AppUpperBaseName }}PubSubHandler(queries, assemblers, subscribers, publishers),
	}
}
